# =========================
# PYTHON & DATI
# =========================
# Ignora l'ambiente virtuale (vitale per non bloccare Overleaf)
python/venv/
python/env/

# Ignora la cache di Python
python/__pycache__/
*.py[cod]

# Ignora i file di dati pesanti (se superano i limiti di GitHub/Overleaf)
# Togli il commento se hai dataset pesanti che non vuoi su Git
# python/data/

# Jupyter Notebook checkpoints
.ipynb_checkpoints/

# =========================
# LATEX (Opzionale, utile per la compilazione locale)
# =========================
# Overleaf gestisce questi file internamente, ma se compili sul tuo PC
# eviterai di sporcare i commit.
*.aux
*.bbl
*.blg
*.log
*.out
*.toc
*.lof

# Ignora la configurazione di PyCharm
.idea/

# Ignora tutti i file immagine raw ovunque si trovino
*.dng
*.raw
*.CR2
*.NEF

# Ignora esplicitamente la cartella dei dati pesanti
python/data/
python/raw_input/
*.lot
*.fls
*.fdb_latexmk
*.synctex.gz
